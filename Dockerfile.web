# ─────────────────────────────────────────────────────────────
# CyberAI Web — Production Container
# ─────────────────────────────────────────────────────────────
# Usage:
#   docker build -f Dockerfile.web -t cyberai .
#   docker run -p 3000:3000 \
#     -e ANTHROPIC_API_KEY=sk-ant-... \
#     -e ADMIN_SECRET=strong-random-secret \
#     cyberai
# ─────────────────────────────────────────────────────────────

# Stage 1: Build
FROM node:20-alpine AS builder

WORKDIR /app

COPY web/package*.json ./
RUN npm ci --include=dev

COPY web/ .

# Build Next.js
ENV NEXT_TELEMETRY_DISABLED=1
RUN npm run build

# Stage 2: Runtime
FROM node:20-alpine AS runner

WORKDIR /app

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1

# Non-root user
RUN addgroup --system --gid 1001 cyberai && \
    adduser --system --uid 1001 cyberai

COPY --from=builder /app/public ./public
COPY --from=builder --chown=cyberai:cyberai /app/.next/standalone ./
COPY --from=builder --chown=cyberai:cyberai /app/.next/static ./.next/static

USER cyberai

EXPOSE 3000
ENV PORT=3000
ENV HOSTNAME="0.0.0.0"

CMD ["node", "server.js"]
