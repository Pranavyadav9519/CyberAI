# ─── CyberAI Environment Configuration ─────────────────────────────────────
# Copy to .env.local and fill in your values.
# Never commit .env.local to version control.

# ── Required ──────────────────────────────────────────────────────────────────
# Anthropic Claude API key
ANTHROPIC_API_KEY=sk-ant-...

# Backend API URL (if using a separate express/bun backend)
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# ── Security ──────────────────────────────────────────────────────────────────
# Admin bypass secret — set a strong random value; used in X-CyberAI-Admin header
# ⚠️  WARNING: Admin mode disables content restrictions. Keep this secret!
ADMIN_SECRET=change-me-strong-random-value-here

# Optional API key required from clients (leave empty to disable)
CYBERAI_API_KEY=

# CORS: allowed origin(s), comma-separated. Use * to allow all (default)
CORS_ORIGIN=*

# Rate limiting: requests per minute per IP (default 60)
RATE_LIMIT_RPM=60

# ── Audit Logging ─────────────────────────────────────────────────────────────
# Path to audit log file (stdout if empty)
AUDIT_LOG_FILE=

# Set to "true" to redact message content from audit logs
AUDIT_REDACT_PII=false

# ── External Integrations ─────────────────────────────────────────────────────
# NVD (National Vulnerability Database) API key for higher rate limits
# Get one at: https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=

# VirusTotal API key for IOC enrichment
# Get one at: https://www.virustotal.com/gui/my-apikey
VIRUSTOTAL_API_KEY=

# ── Voice Features (Gemini AI) ────────────────────────────────────────────────
# Google Gemini API key for JARVIS-style voice interactions (gemini-2.0-flash)
# Get one at: https://aistudio.google.com/app/apikey
# If not set, voice features gracefully degrade with an informative message.
GEMINI_API_KEY=
